{
  "manifest_version": 3,
  "name": "ZZZ Dashboard",
  "icons": {
    "128": "icon.png"
  },
  "version": "0.9",
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "*://*.hoyolab.com/*",
    "*://*.mihoyo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open ZZZ Dashboard"
  }
}